# LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Search APIs
SERPER_API_KEY=your_serper_api_key_here
BRAVE_SEARCH_API_KEY=your_brave_search_key_here

# Notion Integration
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_PAGE_ID=your_notion_page_id

# Google APIs
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_secret
GOOGLE_SHEETS_API_KEY=your_sheets_api_key

# Meta/WhatsApp APIs
WHATSAPP_API_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_token

# Payment APIs (for sales data)
RAZORPAY_API_KEY=your_razorpay_key
RAZORPAY_SECRET=your_razorpay_secret

# Application Configuration
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
CHROMA_PERSIST_DIR=./chroma_db
DATABASE_URL=sqlite:///./omniagent.db

# Agent Configuration
MAX_RETRY_ATTEMPTS=3
CONFIDENCE_THRESHOLD=7.0

# File Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Environment
ENVIRONMENT=development
DEBUG=true
